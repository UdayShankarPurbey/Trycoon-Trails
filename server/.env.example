# ============ APP ============
NODE_ENV=development
PORT=8000
CORS_ORIGIN=http://localhost:4200

# ============ DATABASE (MySQL) ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trycoon_trails
DB_DIALECT=mysql

# ============ REDIS ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ JWT ============
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_REFRESH_EXPIRY=7d

# ============ CLOUDINARY ============
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============ ADMIN SEED ============
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@trycoon.local
ADMIN_PASSWORD=ChangeMe@123

# ============ STARTING RESOURCES ============
STARTER_COINS=1000
STARTER_GEMS=50
STARTER_MANPOWER=100
SHIELD_DAYS=7

# ============ INCOME TICK ============
INCOME_TICK_ENABLED=true
INCOME_TICK_CRON=* * * * *

# ============ MISC ============
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
